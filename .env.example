# Anthropic Claude API key（必填）
ANTHROPIC_API_KEY=

# 可选：自定义 API base url（走代理或兼容网关时填）
# ANTHROPIC_BASE_URL=

# 可选：默认模型，不填用内置默认
# NOVEL_MODEL=claude-opus-4-8

# 通义 text-embedding 的 key（向量召回需要；走 DashScope）
# 不填则 write 时自动跳过向量召回，其余功能不受影响
DASHSCOPE_API_KEY=

# 可选：embedding 端点 / 模型 / 维度，不填用内置默认
# EMBED_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# EMBED_MODEL=text-embedding-v4
# EMBED_DIM=1024
